headers = sched.h sys/syscall.h
headerFilter = sched.h sys/syscall.h
package = platform.linux
compilerOpts = -D_GNU_SOURCE
---

// Namespace flags for clone/unshare
static inline int _CLONE_NEWNS() {
    return CLONE_NEWNS;
}

static inline int _CLONE_NEWUTS() {
    return CLONE_NEWUTS;
}

static inline int _CLONE_NEWIPC() {
    return CLONE_NEWIPC;
}

static inline int _CLONE_NEWUSER() {
    return CLONE_NEWUSER;
}

static inline int _CLONE_NEWPID() {
    return CLONE_NEWPID;
}

static inline int _CLONE_NEWNET() {
    return CLONE_NEWNET;
}

// Other clone flags
static inline int _CLONE_PARENT() {
    return CLONE_PARENT;
}

// CLONE_NEWCGROUP may not be in older headers; #define it ourselves at value 0x02000000.
#ifndef CLONE_NEWCGROUP
#define CLONE_NEWCGROUP 0x02000000
#endif
static inline int _CLONE_NEWCGROUP() {
    return CLONE_NEWCGROUP;
}

// setns(2) wrapper. nstype acts as a guard against opening the wrong kind of fd
// (pass 0 to disable the check). Returns 0 on success or -1 with errno set.
static inline int setns_wrapper(int fd, int nstype) {
    return setns(fd, nstype);
}
